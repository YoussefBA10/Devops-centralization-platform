{{ define "email.monetique.subject" }}[{{ .Status | toUpper }}{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}] Monétique Eye - {{ .CommonLabels.alertname }}{{ end }}

{{ define "email.monetique.html" }}
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background-color:#0a0a0c;font-family:'Segoe UI',Roboto,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0a0a0c;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#111114;border-radius:16px;border:1px solid rgba(255,255,255,0.06);overflow:hidden;">
          
          <!-- Header with Logo -->
          <tr>
            <td style="background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);padding:32px 40px;text-align:center;border-bottom:1px solid rgba(255,255,255,0.06);">
              <img src="data:image/png;base64," alt="Monétique Tunisie" width="200" style="display:block;margin:0 auto 16px auto;" />
              <h1 style="margin:0;color:#ffffff;font-size:22px;font-weight:700;letter-spacing:-0.5px;">Operational Intelligence</h1>
              <p style="margin:8px 0 0;color:rgba(255,255,255,0.5);font-size:12px;text-transform:uppercase;letter-spacing:2px;">Incident Notification</p>
            </td>
          </tr>

          <!-- Status Banner -->
          <tr>
            <td style="padding:0;">
              {{ if eq .Status "firing" }}
              <div style="background:linear-gradient(90deg,#dc2626 0%,#991b1b 100%);padding:14px 40px;text-align:center;">
                <span style="color:#ffffff;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">🔴 FIRING — {{ .Alerts.Firing | len }} Active Alert{{ if gt (len .Alerts.Firing) 1 }}s{{ end }}</span>
              </div>
              {{ else }}
              <div style="background:linear-gradient(90deg,#059669 0%,#047857 100%);padding:14px 40px;text-align:center;">
                <span style="color:#ffffff;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:3px;">✅ RESOLVED</span>
              </div>
              {{ end }}
            </td>
          </tr>

          <!-- Alerts -->
          <tr>
            <td style="padding:32px 40px;">
              {{ range .Alerts }}
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:20px;background-color:#1a1a1f;border-radius:12px;border:1px solid rgba(255,255,255,0.06);overflow:hidden;">
                <!-- Alert Header -->
                <tr>
                  <td style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,0.04);">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <span style="display:inline-block;padding:4px 10px;border-radius:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;
                            {{ if eq .Labels.severity "critical" }}background-color:rgba(220,38,38,0.15);color:#ef4444;border:1px solid rgba(220,38,38,0.3);
                            {{ else }}background-color:rgba(245,158,11,0.15);color:#f59e0b;border:1px solid rgba(245,158,11,0.3);{{ end }}">
                            {{ .Labels.severity | toUpper }}
                          </span>
                        </td>
                        <td align="right">
                          <span style="color:rgba(255,255,255,0.3);font-size:11px;">{{ .StartsAt.Format "2006-01-02 15:04:05" }}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <!-- Alert Body -->
                <tr>
                  <td style="padding:20px;">
                    <h3 style="margin:0 0 8px;color:#ffffff;font-size:16px;font-weight:600;">{{ .Labels.alertname }}</h3>
                    <p style="margin:0 0 12px;color:rgba(255,255,255,0.7);font-size:14px;line-height:1.5;">{{ .Annotations.summary }}</p>
                    {{ if .Annotations.description }}
                    <p style="margin:0;padding:12px 16px;background-color:rgba(255,255,255,0.03);border-radius:8px;border-left:3px solid #3b82f6;color:rgba(255,255,255,0.5);font-size:13px;line-height:1.5;">{{ .Annotations.description }}</p>
                    {{ end }}
                  </td>
                </tr>
                <!-- Alert Labels -->
                <tr>
                  <td style="padding:0 20px 16px;">
                    <table cellpadding="0" cellspacing="0">
                      {{ if .Labels.instance }}
                      <tr>
                        <td style="padding:3px 12px 3px 0;color:rgba(255,255,255,0.3);font-size:11px;text-transform:uppercase;letter-spacing:1px;">Instance</td>
                        <td style="padding:3px 0;color:#60a5fa;font-size:12px;font-family:monospace;">{{ .Labels.instance }}</td>
                      </tr>
                      {{ end }}
                      {{ if .Labels.nodename }}
                      <tr>
                        <td style="padding:3px 12px 3px 0;color:rgba(255,255,255,0.3);font-size:11px;text-transform:uppercase;letter-spacing:1px;">Node</td>
                        <td style="padding:3px 0;color:#60a5fa;font-size:12px;font-family:monospace;">{{ .Labels.nodename }}</td>
                      </tr>
                      {{ end }}
                      {{ if .Labels.name }}
                      <tr>
                        <td style="padding:3px 12px 3px 0;color:rgba(255,255,255,0.3);font-size:11px;text-transform:uppercase;letter-spacing:1px;">Container</td>
                        <td style="padding:3px 0;color:#60a5fa;font-size:12px;font-family:monospace;">{{ .Labels.name }}</td>
                      </tr>
                      {{ end }}
                      {{ if .Labels.container_label_com_monetique_category }}
                      <tr>
                        <td style="padding:3px 12px 3px 0;color:rgba(255,255,255,0.3);font-size:11px;text-transform:uppercase;letter-spacing:1px;">Category</td>
                        <td style="padding:3px 0;color:#60a5fa;font-size:12px;font-family:monospace;">{{ .Labels.container_label_com_monetique_category }}</td>
                      </tr>
                      {{ end }}
                      {{ if .Labels.container_label_com_monetique_environment }}
                      <tr>
                        <td style="padding:3px 12px 3px 0;color:rgba(255,255,255,0.3);font-size:11px;text-transform:uppercase;letter-spacing:1px;">Environment</td>
                        <td style="padding:3px 0;color:#10b981;font-size:12px;font-family:monospace;">{{ .Labels.container_label_com_monetique_environment }}</td>
                      </tr>
                      {{ end }}
                    </table>
                  </td>
                </tr>
              </table>
              {{ end }}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 40px;border-top:1px solid rgba(255,255,255,0.04);text-align:center;">
              <p style="margin:0 0 4px;color:rgba(255,255,255,0.25);font-size:11px;">Monétique Eye — Operational Intelligence Platform</p>
              <p style="margin:0;color:rgba(255,255,255,0.15);font-size:10px;">This is an automated alert from your infrastructure monitoring system.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
{{ end }}
